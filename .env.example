# MindMirror Frontend Configuration
# Copy this file to .env.local (Vite only reads .env / .env.local / .env.[mode])

# Base URL of the FastAPI backend. The frontend hits `${VITE_API_BASE_URL}/auth/login` etc.
# - In Docker Compose (default): nginx proxies /api -> backend, so leave empty to use the relative path.
# - Local dev (vite dev server): set to http://localhost:8000/api/v1
VITE_API_BASE_URL=

# Repository URL used in the About page when linking to the user guide.
# Defaults to the GitHub repo when not set.
VITE_REPO_URL=
