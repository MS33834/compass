[
  {
    "name": "vendor-react (React + ReactDOM + Zustand)",
    "path": "dist/assets/vendor-react-*.js",
    "limit": "200 KB",
    "gzip": true
  },
  {
    "name": "index (应用主 bundle)",
    "path": "dist/assets/index-*.js",
    "limit": "80 KB",
    "gzip": true
  },
  {
    "name": "figures (人物数据)",
    "path": "dist/assets/figures-*.js",
    "limit": "120 KB",
    "gzip": true
  },
  {
    "name": "items (题目数据)",
    "path": "dist/assets/items-*.js",
    "limit": "180 KB",
    "gzip": true
  },
  {
    "name": "css (主样式表)",
    "path": "dist/assets/index-*.css",
    "limit": "20 KB",
    "gzip": true
  },
  {
    "name": "TOTAL gzipped (所有 JS+CSS)",
    "path": "dist/assets/*.{js,css}",
    "limit": "280 KB",
    "gzip": true
  }
]
