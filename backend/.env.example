# Copy to .env and edit. Blank lines are fine.

# --- Required in production ----------------------------------------------------
# Sign JWTs. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# Production refuses to boot if this is the dev placeholder or < 32 chars.
SECRET_KEY=replace-me-with-a-random-string-at-least-32-chars

# Comma-separated allow-list. Wildcard is rejected (we send credentials).
# Production refuses to boot if this is unset.
CORS_ORIGIN=http://localhost:5173,http://localhost:4173

# "production" or "development" (default). Controls how strict startup checks are.
ENVIRONMENT=development

# --- Optional ------------------------------------------------------------------
# DATABASE_URL is auto-derived from POSTGRES_USER / POSTGRES_PASSWORD /
# POSTGRES_DB when running under docker compose. Set this only when pointing
# the backend at an external database.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080          # 7 days

PROJECT_NAME=MindMirror API
VERSION=1.0.0
API_V1_STR=/api/v1
