{
  "name": "compass",
  "version": "0.3.0",
  "private": true,
  "description": "Compass · a quiet compass for the inner self. Answer 48 questions across a 12-dimensional trait space to find your historical counterpart across 5 domains, 150 figures, 240 items. Local-first, no server, no tracking.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:pages": "tsc -b && vite build --base=/compass/",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "tsx tests/golden.spec.mjs",
    "test:unit": "tsx tests/unit.spec.mjs",
    "test:all": "tsx tests/golden.spec.mjs && tsx tests/unit.spec.mjs",
    "test:e2e": "node tests/e2e.mjs",
    "test:axe": "node tests/axe.mjs",
    "test:full": "node tests/full-interaction.mjs",
    "test:deep": "node tests/deep-interaction.mjs",
    "test:figure": "node tests/figure-detail-check.mjs",
    "test:share": "node tests/share-card-check.mjs",
    "test:ui": "node tests/ui-audit.mjs",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\" \"*.{json,js,mjs,md,yml,yaml}\" \"tests/**/*.mjs\" \"scripts/**/*.mjs\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,md}\" \"*.{json,js,mjs,md,yml,yaml}\" \"tests/**/*.mjs\" \"scripts/**/*.mjs\"",
    "gen:portraits": "node scripts/gen-portraits.mjs",
    "gen:icons": "node scripts/gen-icons.mjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MS33834/compass.git"
  },
  "keywords": [
    "compass",
    "trait-space",
    "personality-test",
    "historical-figures",
    "literati",
    "local-first",
    "privacy",
    "pwa",
    "static-site",
    "gitcode-pages",
    "react",
    "typescript",
    "vite"
  ],
  "author": {
    "name": "badhope",
    "url": "https://gitcode.com/badhope"
  },
  "license": "PolyForm-Noncommercial-1.0.0",
  "bugs": {
    "url": "https://github.com/MS33834/compass/issues"
  },
  "homepage": "https://badhope.gitcode.host/compass/",
  "dependencies": {
    "gsap": "^3.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "axe-core": "^4.12.1",
    "playwright": "^1.49.0",
    "prettier": "^3.3.3",
    "tsx": "^4.22.4",
    "typescript": "~5.5.3",
    "vite": "^8.0.16",
    "wait-on": "^8.0.0"
  }
}
